# ========================================
# GOAT Royalty App - Environment Configuration
# ========================================
# Copy this file to .env.local and fill in your API keys
# NEVER commit .env.local to version control!
# ========================================

# ========================================
# SUPABASE AUTHENTICATION & DATABASE
# ========================================
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ========================================
# MUSIC DISTRIBUTION SERVICES
# ========================================

# DistroKid API (for bulk music distribution)
# Get your API key at: https://distrokid.com/api-settings/
DISTROKID_API_KEY=your-distrokid-api-key

# TuneCore API (alternative distribution)
# Get your credentials at: https://www.tunecore.com/api
TUNECORE_API_KEY=your-tunecore-api-key
TUNECORE_API_SECRET=your-tunecore-api-secret

# CD Baby API (alternative distribution)
# Get your API key at: https://members.cdbaby.com/api
CDBABY_API_KEY=your-cdbaby-api-key

# ========================================
# ROYALTY TRACKING SERVICES
# ========================================

# MLC (Mechanical Licensing Collective)
# Register at: https://www.themlc.com/
MLC_API_KEY=your-mlc-api-key
MLC_MEMBER_ID=your-mlc-member-id

# SoundExchange (Performance Royalties)
# Register at: https://www.soundexchange.com/
SOUNDEXCHANGE_API_KEY=your-soundexchange-api-key
SOUNDEXCHANGE_API_SECRET=your-soundexchange-api-secret
SOUNDEXCHANGE_ARTIST_ID=your-artist-id

# ========================================
# TIKTOK INTEGRATION
# ========================================

# TikTok Developer App
# Create at: https://developers.tiktok.com/
TIKTOK_CLIENT_ID=your-tiktok-client-id
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret
TIKTOK_REDIRECT_URI=http://localhost:3000/api/tiktok/callback

# TikAPI (TikTok data API - used for profile lookup & analytics)
# Get your API key at: https://tikapi.io/
NEXT_PUBLIC_TIKAPI_KEY=your-tikapi-key

# ========================================
# SPOTIFY INTEGRATION
# ========================================
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/spotify/callback

# ========================================
# AI SERVICES
# ========================================

# Google Gemini AI
# Get API key at: https://ai.google.dev/
GOOGLE_GEMINI_API_KEY=your-gemini-api-key

# OpenAI (for AI chat features)
OPENAI_API_KEY=your-openai-api-key

# Anthropic Claude (alternative AI)
ANTHROPIC_API_KEY=your-anthropic-api-key

# ========================================
# HOSTING & DEPLOYMENT
# ========================================

# Hostinger VPS (for deployment)
# Get your API token at: https://developers.hostinger.com/
HOSTINGER_API_TOKEN=your-hostinger-api-token
HOSTINGER_VPS_ID=your-vps-id

# Vercel (alternative hosting)
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-org-id
VERCEL_PROJECT_ID=your-project-id

# ========================================
# SECURITY & ENCRYPTION
# ========================================

# Encryption key for API key storage
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=your-encryption-key

# Session secret
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# ========================================
# APPLICATION SETTINGS
# ========================================

# Environment: development, production, staging
NODE_ENV=development

# Port for development server
PORT=3000

# API base URL (for production)
NEXT_PUBLIC_API_URL=http://localhost:3000

# ========================================
# FEATURE FLAGS
# ========================================

# Enable demo mode (uses mock data)
ENABLE_DEMO_MODE=true

# Enable demo authentication
ENABLE_DEMO_AUTH=true

# Enable analytics tracking
ENABLE_ANALYTICS=false

# Enable error reporting
ENABLE_ERROR_REPORTING=false

# Sentry DSN (for error tracking)
# NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn

# ========================================
# CATALOG DATA
# ========================================

# Music catalog paths
FASTASSMAN_CATALOG_PATH=./data/catalogs/FASTASSMAN_MUSIC_CATALOG.csv
HARVEY_MILLER_CATALOG_PATH=./data/catalogs/WorksCatalog2 HARVEY L MILLER WRITERS.csv

# Default publisher information
DEFAULT_PUBLISHER_NAME=FASTASSMAN PUBLISHING INC
DEFAULT_PUBLISHER_AFFILIATION=ASCAP