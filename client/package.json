{
  "name": "goat-royalty-app",
  "version": "1.0.0",
  "description": "GOAT Royalty Management System - A comprehensive royalty management platform for artists and content creators.",
  "author": "GOAT Royalty <contact@goatroyalty.com>",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:pack": "electron-builder --dir",
    "electron:dist:win": "electron-builder --win --x64",
    "electron:dist:mac": "electron-builder --mac",
    "electron:dist:linux": "electron-builder --linux",
    "electron:dist:all": "electron-builder -mwl",
    "pwa:build": "next build && next export"
  },
  "main": "public/electron.js",
  "homepage": "./",
  "build": {
    "appId": "com.goatroyalty.app",
    "productName": "GOAT Royalty App",
    "directories": {
      "output": "dist",
      "buildResources": "build-resources"
    },
    "files": [
      "out/**/*",
      "public/electron.js",
      "public/preload.js"
    ],
    "extraResources": [
      {
        "from": "out",
        "to": "app/out",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        {
          "target": "dir",
          "arch": ["x64"]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": ["x64"]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "dir",
          "arch": ["x64"]
        }
      ],
      "category": "Office"
    }
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@reduxjs/toolkit": "^2.11.0",
    "axios": "^1.13.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.555.0",
    "next": "16.0.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.67.0",
    "react-redux": "^9.2.0",
    "recharts": "^3.5.1",
    "tailwind-merge": "^3.4.0",
    "wait-on": "^9.0.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.0.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}