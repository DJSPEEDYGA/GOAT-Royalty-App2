{
  "name": "goat-royalty-app",
  "version": "1.0.0",
  "description": "Music royalty management platform for artists and rights holders",
  "authors": [
    "HARVEY L MILLER JR <harvey@goatroyaltyapp.com>",
    "JUAQUIN J MALPHURS <juaquin@goatroyaltyapp.com>",
    "KEVIN W HALLINGQUEST <kevin@goatroyaltyapp.com>"
  ],
  "main": "main.js",
  "license": "UNLICENSED",
  "copyright": "Copyright © 2024 HARVEY L MILLER JR / JUAQUIN J MALPHURS / KEVIN W HALLINGQUEST. All rights reserved.",
  "owner": "HARVEY L MILLER JR / JUAQUIN J MALPHURS / KEVIN W HALLINGQUEST",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "electron": "electron .",
    "start-electron": "npm run build && electron .",
    "build:win": "npm run build && electron-builder --win --config electron-builder.yml",
    "build:mac": "npm run build && electron-builder --mac --config electron-builder.yml",
    "build:linux": "npm run build && electron-builder --linux --config electron-builder.yml",
    "build:portable": "npm run build && electron-builder --win portable --config electron-builder.yml",
    "build:all": "npm run build && electron-builder --win --mac --linux --config electron-builder.yml",
    "build:win-exe": "npm run build && electron-builder --win nsis --config electron-builder.yml",
    "build:dmg": "npm run build && electron-builder --mac dmg --config electron-builder.yml",
    "build:appimage": "npm run build && electron-builder --linux AppImage --config electron-builder.yml",
    "build:deb": "npm run build && electron-builder --linux deb --config electron-builder.yml",
    "electron:build:win": "electron-builder --win --config electron-builder.yml",
    "electron:build:mac": "electron-builder --mac --config electron-builder.yml",
    "electron:build:linux": "electron-builder --linux --config electron-builder.yml",
    "electron-builder": "electron-builder",
    "postinstall": "echo 'Postinstall complete'",
    "release": "npm run build && electron-builder --win --mac --linux --publish always --config electron-builder.yml"
  },
  "build": {
    "appId": "com.goatroyalty.app",
    "productName": "GOAT Royalty App",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "start-server.js",
      ".next/**/*",
      "public/**/*",
      "pages/**/*",
      "components/**/*",
      "styles/**/*",
      "lib/**/*",
      "node_modules/**/*",
      "package.json",
      "next.config.js"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "GOAT-Royalty-App-Portable.exe"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/icon.icns",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Office",
      "maintainer": "Harvey L Miller Jr <harvey@goatroyaltyapp.com>"
    },
    "publish": null
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/auth-helpers-nextjs": "^0.15.0",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.78.0",
    "axios": "^1.6.0",
    "dompurify": "^3.3.3",
    "dotenv": "^17.2.3",
    "libreoffice-convert": "^1.7.0",
    "lucide-react": "^0.309.0",
    "marked": "^16.4.1",
    "next": "^14.1.0",
    "next-auth": "^4.24.13",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tikapi": "^3.2.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.16",
    "electron": "^28.1.3",
    "electron-builder": "^24.13.2",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0"
  }
}
