{
  "name": "super-goat-royalties",
  "version": "1.0.0",
  "description": "SUPER GOAT ROYALTIES APP - Music Royalty Management Platform",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win --mac --linux"
  },
  "author": "GOAT Royalties",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "next": "^14.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "build": {
    "appId": "com.goatroyalties.app",
    "productName": "SUPER GOAT ROYALTIES APP",
    "copyright": "Copyright © 2024 GOAT Royalties",
    "directories": {
      "output": "../output"
    },
    "files": [
      "**/*",
      "app/**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md}",
      "!**/node_modules/.bin",
      "!**/.git"
    ],
    "extraResources": [
      {
        "from": "../../.next",
        "to": "app/.next",
        "filter": ["**/*"]
      },
      {
        "from": "../../pages",
        "to": "app/pages",
        "filter": ["**/*"]
      },
      {
        "from": "../../public",
        "to": "app/public",
        "filter": ["**/*"]
      },
      {
        "from": "../../components",
        "to": "app/components",
        "filter": ["**/*"]
      },
      {
        "from": "../../lib",
        "to": "app/lib",
        "filter": ["**/*"]
      },
      {
        "from": "../../data",
        "to": "app/data",
        "filter": ["**/*"]
      },
      {
        "from": "../../styles",
        "to": "app/styles",
        "filter": ["**/*"]
      },
      {
        "from": "../../package.json",
        "to": "app/package.json"
      },
      {
        "from": "../../next.config.js",
        "to": "app/next.config.js"
      },
      {
        "from": "../../server.js",
        "to": "app/server.js"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SUPER GOAT ROYALTIES APP"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "icon.icns",
      "category": "public.app-category.music"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "tar.gz"
      ],
      "icon": "icon.png",
      "category": "Audio;Music;"
    }
  }
}