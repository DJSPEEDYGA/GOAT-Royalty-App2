# Google Drive Pipeline Configuration

# Google Drive API Credentials
GOOGLE_DRIVE_CLIENT_ID=your-client-id
GOOGLE_DRIVE_CLIENT_SECRET=your-client-secret
GOOGLE_DRIVE_REFRESH_TOKEN=your-refresh-token
GOOGLE_DRIVE_FOLDER_ID=17RV_P-8vWxnX6cmkJI_WF4He2kbiUaVf

# Pipeline Settings
PIPELINE_SYNC_INTERVAL=300000
PIPELINE_BATCH_SIZE=50
PIPELINE_MAX_FILE_SIZE=1073741824
PIPELINE_ENABLE_COMPRESSION=true

# Data Processor Settings
PROCESSOR_ENABLE_CACHE=true
PROCESSOR_CACHE_SIZE=1000

# AI Hub Settings
AIHUB_ENABLE_SEARCH=true
AIHUB_MAX_CACHE_SIZE=100
AIHUB_INDEX_PATH=./pipeline/metadata

# Pipeline Directory Paths
PIPELINE_ROOT_DIR=.
PIPELINE_INPUT_DIR=./pipeline/input
PIPELINE_OUTPUT_DIR=./pipeline/output
PIPELINE_PROCESSING_DIR=./pipeline/processing
PIPELINE_CACHE_DIR=./pipeline/cache
PIPELINE_LOGS_DIR=./pipeline/logs
PIPELINE_METADATA_DIR=./pipeline/metadata
PIPELINE_AI_ACCESS_DIR=./pipeline/ai-access